# ================================
# RESERA Backend — Development
# ================================
NODE_ENV=development
PORT=3000

# ── Base de datos (Supabase — Transaction Pooler) ─────────────
DATABASE_URL=postgresql://postgres.xhtsriuwmqgvobfqmpeh:qEGxek5O3KaRXLLZ@aws-1-sa-east-1.pooler.supabase.com:6543/postgres
DB_SSL=true
DB_LOGGING=false

# ── JWT ───────────────────────────────────────────────────────
JWT_SECRET=resera_jwt_secret_dev_2024_cambiar_en_prod
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=resera_refresh_secret_dev_2024_cambiar_en_prod
JWT_REFRESH_EXPIRES_IN=7d

# ── Seguridad ─────────────────────────────────────────────────
BCRYPT_ROUNDS=10
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# ── Rate Limiting ─────────────────────────────────────────────
THROTTLE_LIMIT=60

# ── Mercado Pago ──────────────────────────────────────────────
MP_ACCESS_TOKEN=
MP_WEBHOOK_SECRET=
MP_NOTIFICATION_URL=

# ── Swagger ───────────────────────────────────────────────────
SWAGGER_ENABLED=true
SWAGGER_PATH=docs

# ── Frontend URL (para back_urls de MP) ───────────────────────
FRONTEND_URL=http://localhost:5173

# ── Timers ────────────────────────────────────────────────────
SEÑA_PAYMENT_HOURS=24